# ---------------------------------------------------------------------------
# fhir2uml configuration
#
# Referenced from docker-compose.yml via `env_file`. Copy, edit, and keep this
# out of version control if it holds environment-specific values.
# ---------------------------------------------------------------------------

# --- PlantUML rendering -----------------------------------------------------
# Base URL of the PlantUML HTTP server used to rasterize UML text into PNG/SVG.
# The converter only emits PlantUML text; this server does the image rendering.
#   - Public TermX demo server: https://demo.termx.org/plantuml
#   - Bundled local server:     http://plantuml:8080  (see docker-compose.example.yml)
PLANT_UML_URL=https://demo.termx.org/plantuml

# --- Server -----------------------------------------------------------------
# Port the REST API listens on inside the container. If you change this, update
# the published port in docker-compose.yml to match.
SERVER_PORT=8080

# --- JVM (optional) ---------------------------------------------------------
# Heap caps are applied to BOTH the server and the converter subprocess it
# spawns (the `java` launcher reads JDK_JAVA_OPTIONS automatically). Size these
# to your container's memory limit; with two JVMs at peak, keep the sum < limit.
# JDK_JAVA_OPTIONS=-XX:MaxRAMPercentage=40 -XX:+ExitOnOutOfMemoryError
